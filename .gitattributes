# Handle line endings automatically for files detected as text
* text=auto

# Enforce LF for source and docs
*.cpp text eol=lf
*.hpp text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Vendored tokenizer ranks: exact bytes must be preserved (SHA-256 verified),
# so never apply line-ending normalization or treat as diffable text.
*.tiktoken binary
